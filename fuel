interface Vehicle {
    void start();

    default void fuelType() { 
        System.out.println("Runs on gasoline");
    }
}

class Car implements Vehicle {
    public void start() {
        System.out.println("Car started");
    }
}

public class Main {
    public static void main(String[] args) {
        Car myCar = new Car();
        myCar.start();    
        myCar.fuelType(); 
    }
}
