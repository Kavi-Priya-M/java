
import java.io.*;

class Geeks {
    public static void main(String args[]) {
        
        char ch = 'c';
        
        // Make the list of vowels
        String str = "aeiouAEIOU";
        
        // str is a list of vowels
        if(str.indexOf(ch) == -1) {
            System.out.print(ch+" is a consonant");
        }else {
            System.out.print(ch+" is a vowel");
        }
    }

}
